# Copy this file to .env.test and fill in real values before running tests.
# .env.test is gitignored — NEVER commit it.
# Tests TRUNCATE tables, so DATABASE_URL must point at a separate test database.

NODE_ENV=test
DATABASE_URL=postgresql://postgres:YOUR_PASS@localhost:5433/decoinks_test
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace_with_at_least_32_random_characters_here
JWT_EXPIRES_IN=7d
JWT_SUPPLIER_EXPIRY=7d
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/svg+xml,application/pdf
